GEMINI_API_KEY=your_gemini_api_key_here
SARVAM_API_KEY=your_sarvam_api_key_here
FRONTEND_URL=http://localhost:3000
SPRING_BACKEND_URL=http://localhost:8080
WHISPER_MODEL=base
# Shared secret between Spring Boot Gateway and FastAPI — generate with: openssl rand -hex 32
INTERNAL_API_KEY=your-random-secret-here

# v5.0 — MongoDB Atlas (Mumbai region in prod). Local dev: docker run --name yojna-mongo -p 27017:27017 mongo:7
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=yojnasetu
# Dev-only auth bypass for the Orchestrator before Spring Boot OTP/JWT lands (Phase 1). Never set in prod.
DEV_AUTH_BYPASS=true

# ── Document OCR (utils/vision_ocr.py) ──────────────────────────────────
# Primary OCR is a local Ollama vision model (reads ANY Indian script, keeps
# ID photos on-device). Pull it once:  ollama pull granite3.2-vision
# Without it, OCR falls back to EasyOCR automatically.
OCR_VISION_MODEL=granite3.2-vision      # or qwen2.5vl:3b for higher accuracy where VRAM allows
OCR_FALLBACK_LANGS=hi,en                # EasyOCR fallback languages (Devanagari+Latin)
